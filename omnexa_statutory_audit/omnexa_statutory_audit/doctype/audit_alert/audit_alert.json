{
  "doctype": "DocType",
  "name": "Audit Alert",
  "module": "Omnexa Statutory Audit",
  "custom": 0,
  "istable": 0,
  "is_submittable": 0,
  "autoname": "format:AAL-{####}",
  "naming_rule": "Expression (Old Style)",
  "track_changes": 1,
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "title",
  "search_fields": "title,rule_code,reference_doctype,reference_name,status",
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "New\nInvestigating\nConfirmed\nFalse Positive\nClosed",
      "default": "New",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "severity",
      "fieldtype": "Select",
      "label": "Severity",
      "options": "Critical\nHigh\nMedium\nLow",
      "default": "High",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "applies_to",
      "fieldtype": "Select",
      "label": "Area",
      "options": "Sales\nPurchasing\nInventory\nBanking\nGL\nPayroll\nSecurity",
      "default": "GL",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "rule",
      "fieldtype": "Link",
      "label": "Rule",
      "options": "Audit Risk Rule"
    },
    {
      "fieldname": "rule_code",
      "fieldtype": "Data",
      "label": "Rule Code",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "reference_doctype",
      "fieldtype": "Link",
      "label": "Reference DocType",
      "options": "DocType",
      "in_list_view": 1
    },
    {
      "fieldname": "reference_name",
      "fieldtype": "Dynamic Link",
      "label": "Reference Document",
      "options": "reference_doctype",
      "in_list_view": 1
    },
    {
      "fieldname": "company",
      "fieldtype": "Link",
      "label": "Company",
      "options": "Company",
      "in_list_view": 1
    },
    {
      "fieldname": "owner_user",
      "fieldtype": "Link",
      "label": "Owner",
      "options": "User",
      "description": "Investigation owner"
    },
    {
      "fieldname": "detected_on",
      "fieldtype": "Datetime",
      "label": "Detected On",
      "default": "Now",
      "reqd": 1
    },
    {
      "fieldname": "evidence_json",
      "fieldtype": "Long Text",
      "label": "Evidence JSON",
      "read_only": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "report": 1,
      "export": 1,
      "print": 1,
      "email": 1
    }
  ]
}

