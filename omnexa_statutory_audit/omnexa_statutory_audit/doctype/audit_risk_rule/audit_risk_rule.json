{
  "doctype": "DocType",
  "name": "Audit Risk Rule",
  "module": "Omnexa Statutory Audit",
  "custom": 0,
  "istable": 0,
  "is_submittable": 0,
  "autoname": "format:ARR-{####}",
  "naming_rule": "Expression (Old Style)",
  "track_changes": 1,
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "title",
  "search_fields": "title,rule_code,applies_to",
  "fields": [
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "1",
      "in_list_view": 1
    },
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Rule Title",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "rule_code",
      "fieldtype": "Data",
      "label": "Rule Code",
      "unique": 1,
      "reqd": 1,
      "in_list_view": 1,
      "description": "Stable identifier used by the engine, e.g. invoice_duplicate"
    },
    {
      "fieldname": "severity",
      "fieldtype": "Select",
      "label": "Severity",
      "options": "Critical\nHigh\nMedium\nLow",
      "default": "High",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "applies_to",
      "fieldtype": "Select",
      "label": "Applies To",
      "options": "Sales\nPurchasing\nInventory\nBanking\nGL\nPayroll\nSecurity",
      "default": "GL",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "query_sql",
      "fieldtype": "Code",
      "label": "Detection SQL (optional)",
      "options": "SQL",
      "description": "If provided, the engine runs this query and expects rows with doctype/name/evidence_json."
    },
    {
      "fieldname": "sample_threshold",
      "fieldtype": "Int",
      "label": "Sample Threshold (optional)",
      "description": "Optional numeric parameter used by some rules."
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "report": 1,
      "export": 1,
      "print": 1,
      "email": 1
    }
  ]
}

