{
  "doctype": "DocType",
  "name": "Audit Remediation Plan",
  "module": "Omnexa Statutory Audit",
  "custom": 0,
  "istable": 0,
  "is_submittable": 0,
  "autoname": "format:ARP-{####}",
  "naming_rule": "Expression (Old Style)",
  "track_changes": 1,
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "title",
  "search_fields": "title,status,investigation",
  "fields": [
    {
      "fieldname": "investigation",
      "fieldtype": "Link",
      "label": "Investigation",
      "options": "Audit Investigation",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "fetch_from": "investigation.title",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Open\nIn Progress\nCompleted\nCancelled",
      "default": "Open",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "owner_user",
      "fieldtype": "Link",
      "label": "Owner",
      "options": "User",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "due_date",
      "fieldtype": "Date",
      "label": "Due Date",
      "in_list_view": 1
    },
    {
      "fieldname": "completed_on",
      "fieldtype": "Date",
      "label": "Completed On"
    },
    {
      "fieldname": "plan",
      "fieldtype": "Small Text",
      "label": "Plan"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "report": 1,
      "export": 1,
      "print": 1,
      "email": 1
    }
  ]
}

