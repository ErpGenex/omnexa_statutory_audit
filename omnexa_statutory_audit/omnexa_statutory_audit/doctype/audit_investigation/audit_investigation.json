{
  "doctype": "DocType",
  "name": "Audit Investigation",
  "module": "Omnexa Statutory Audit",
  "custom": 0,
  "istable": 0,
  "is_submittable": 0,
  "autoname": "format:AIN-{####}",
  "naming_rule": "Expression (Old Style)",
  "track_changes": 1,
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "title",
  "search_fields": "title,status,alert",
  "fields": [
    {
      "fieldname": "alert",
      "fieldtype": "Link",
      "label": "Audit Alert",
      "options": "Audit Alert",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "fetch_from": "alert.title",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Open\nIn Progress\nClosed",
      "default": "Open",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "owner_user",
      "fieldtype": "Link",
      "label": "Owner",
      "options": "User",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "opened_on",
      "fieldtype": "Datetime",
      "label": "Opened On",
      "default": "Now",
      "reqd": 1
    },
    {
      "fieldname": "closed_on",
      "fieldtype": "Datetime",
      "label": "Closed On"
    },
    {
      "fieldname": "conclusion",
      "fieldtype": "Select",
      "label": "Conclusion",
      "options": "\nConfirmed\nFalse Positive\nNeeds Remediation",
      "description": "Set when closing investigation"
    },
    {
      "fieldname": "summary",
      "fieldtype": "Small Text",
      "label": "Summary"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "report": 1,
      "export": 1,
      "print": 1,
      "email": 1
    }
  ]
}

