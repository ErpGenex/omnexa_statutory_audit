{
  "doctype": "DocType",
  "name": "Audit Exception Register",
  "module": "Omnexa Statutory Audit",
  "custom": 0,
  "istable": 0,
  "is_submittable": 0,
  "autoname": "format:AEX-{####}",
  "naming_rule": "Expression (Old Style)",
  "track_changes": 1,
  "sort_field": "modified",
  "sort_order": "DESC",
  "title_field": "title",
  "search_fields": "title,status,reference_doctype,reference_name",
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Open\nIn Progress\nClosed",
      "default": "Open",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "severity",
      "fieldtype": "Select",
      "label": "Severity",
      "options": "Critical\nHigh\nMedium\nLow",
      "default": "High",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "reference_doctype",
      "fieldtype": "Link",
      "label": "Reference DocType",
      "options": "DocType",
      "in_list_view": 1
    },
    {
      "fieldname": "reference_name",
      "fieldtype": "Dynamic Link",
      "label": "Reference Document",
      "options": "reference_doctype",
      "in_list_view": 1
    },
    {
      "fieldname": "owner_user",
      "fieldtype": "Link",
      "label": "Owner",
      "options": "User"
    },
    {
      "fieldname": "opened_on",
      "fieldtype": "Datetime",
      "label": "Opened On",
      "default": "Now"
    },
    {
      "fieldname": "closed_on",
      "fieldtype": "Datetime",
      "label": "Closed On"
    },
    {
      "fieldname": "details",
      "fieldtype": "Long Text",
      "label": "Details"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "report": 1,
      "export": 1,
      "print": 1,
      "email": 1
    }
  ]
}

